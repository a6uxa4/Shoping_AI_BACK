{
  "swagger": "2.0",
  "info": {
    "title": "SHOPPING AI API",
    "description": "API for managing shopping in the Shopping AI application.",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": ["http", "https"],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT: Bearer <token>"
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Вход",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/LoginBody" }
          }
        ],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": { "$ref": "#/definitions/LoginResponse" }
          },
          "401": {
            "description": "Неверные данные",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Текущий пользователь",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": { "$ref": "#/definitions/MeResponse" }
          },
          "401": {
            "description": "Нет токена или неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/chat": {
      "get": {
        "tags": ["Chat"],
        "summary": "История чата с ботом",
        "description": "Возвращает последние сообщения диалога текущего пользователя.",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "data": {
                  "type": "object",
                  "properties": {
                    "messages": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "role": { "type": "string", "enum": ["user", "assistant"] },
                          "content": { "type": "string" },
                          "productIds": { "type": "array", "items": { "type": "string" } }
                        }
                      }
                    },
                    "conversationId": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          },
          "401": { "description": "Нет/неверный токен", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      },
      "post": {
        "tags": ["Chat"],
        "summary": "Отправить сообщение боту",
        "description": "Текст и/или фото. Бот ответит и может приложить подборку товаров (по запросу типа «платье на вечер» или по фото).",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "description": "Текст сообщения (привет, платье на вечер и т.д.)" },
                "image": { "type": "string", "description": "Base64 изображения для поиска по фото (опционально)" },
                "mimeType": { "type": "string", "default": "image/jpeg" }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "data": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "description": "Ответ бота" },
                    "products": {
                      "type": "array",
                      "items": { "$ref": "#/definitions/ProductItem" },
                      "description": "Подобранные товары (если запрос про товары или фото)"
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Нет message и image", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "401": { "description": "Нет/неверный токен", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "503": { "description": "Чат недоступен (нет OPENAI_API_KEY)", "schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      }
    },
    "/api/users/admin": {
      "get": {
        "tags": ["Users"],
        "summary": "Список admin с пагинацией (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "page", "in": "query", "type": "integer", "default": 1 },
          { "name": "limit", "in": "query", "type": "integer", "default": 10 }
        ],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": { "$ref": "#/definitions/GetAdminsResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Создать admin (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/CreateAdminBody" }
          }
        ],
        "responses": {
          "201": {
            "description": "Создан admin",
            "schema": { "$ref": "#/definitions/CreateAdminResponse" }
          },
          "400": {
            "description": "Не хватает данных",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "409": {
            "description": "Пользователь уже существует",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/manual/categories": {
      "get": {
        "tags": ["Manual (справочники)"],
        "summary": "Список категорий товара",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": { "$ref": "#/definitions/GetCategoriesResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "post": {
        "tags": ["Manual (справочники)"],
        "summary": "Создать категорию (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/CategoryBody" }
          }
        ],
        "responses": {
          "201": {
            "description": "Категория создана",
            "schema": { "$ref": "#/definitions/CategoryItemResponse" }
          },
          "400": {
            "description": "Не указано name",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "409": {
            "description": "Категория с таким названием уже существует",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/manual/categories/{id}": {
      "put": {
        "tags": ["Manual (справочники)"],
        "summary": "Обновить категорию (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/CategoryBody" }
          }
        ],
        "responses": {
          "200": {
            "description": "Обновлено",
            "schema": { "$ref": "#/definitions/CategoryItemResponse" }
          },
          "400": {
            "description": "Не указано name",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Категория не найдена",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "409": {
            "description": "Категория с таким названием уже существует",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "delete": {
        "tags": ["Manual (справочники)"],
        "summary": "Удалить категорию (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": {
            "description": "Удалено",
            "schema": { "$ref": "#/definitions/DeleteCategoryResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Категория не найдена",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/users/admin/{id}": {
      "put": {
        "tags": ["Users"],
        "summary": "Обновить admin (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UpdateAdminBody" }
          }
        ],
        "responses": {
          "200": {
            "description": "Обновлено",
            "schema": { "$ref": "#/definitions/UpdateAdminResponse" }
          },
          "400": {
            "description": "Некорректные данные",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Пользователь не найден",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "409": {
            "description": "login уже занят",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Удалить admin (только super_admin)",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": {
            "description": "Удалено",
            "schema": { "$ref": "#/definitions/DeleteAdminResponse" }
          },
          "400": {
            "description": "Можно удалять только admin",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (нужна роль super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Пользователь не найден",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "tags": ["Products"],
        "summary": "Список товаров для клиента (без пагинации)",
        "description": "Возвращает все подходящие товары (макс. 500). Фильтры: category, title, minPrice, maxPrice, season, material, productionCountry. ИИ: q/query — текст, image — base64 фото. Без pagination в ответе.",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "category", "in": "query", "type": "string" },
          { "name": "title", "in": "query", "type": "string" },
          { "name": "minPrice", "in": "query", "type": "number" },
          { "name": "maxPrice", "in": "query", "type": "number" },
          { "name": "season", "in": "query", "type": "string" },
          { "name": "material", "in": "query", "type": "string" },
          { "name": "productionCountry", "in": "query", "type": "string" },
          {
            "name": "q",
            "in": "query",
            "type": "string",
            "description": "ИИ по тексту (напр. одежда на вечер)"
          },
          {
            "name": "query",
            "in": "query",
            "type": "string",
            "description": "То же что q"
          },
          {
            "name": "image",
            "in": "query",
            "type": "string",
            "description": "ИИ по фото: base64"
          },
          {
            "name": "mimeType",
            "in": "query",
            "type": "string",
            "default": "image/jpeg"
          }
        ],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "data": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": { "$ref": "#/definitions/ProductItem" }
                    },
                    "aiUsed": { "type": "boolean" },
                    "query": { "type": "string" },
                    "describedAs": { "type": "string" },
                    "aiFilters": { "type": "object" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "503": {
            "description": "ИИ недоступен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Создать товар",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/CreateProductBody" }
          }
        ],
        "responses": {
          "201": {
            "description": "Товар создан",
            "schema": { "$ref": "#/definitions/ProductItemResponse" }
          },
          "400": {
            "description": "Не указаны title/category или категория не найдена",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (admin или super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/products/admin": {
      "get": {
        "tags": ["Products"],
        "summary": "Список товаров для админки (с пагинацией)",
        "description": "Только admin/super_admin. Те же фильтры и ИИ (q, query, image), в ответе pagination: page, limit, total, totalPages.",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "page", "in": "query", "type": "integer", "default": 1 },
          { "name": "limit", "in": "query", "type": "integer", "default": 10 },
          { "name": "category", "in": "query", "type": "string" },
          { "name": "title", "in": "query", "type": "string" },
          { "name": "minPrice", "in": "query", "type": "number" },
          { "name": "maxPrice", "in": "query", "type": "number" },
          { "name": "season", "in": "query", "type": "string" },
          { "name": "material", "in": "query", "type": "string" },
          { "name": "productionCountry", "in": "query", "type": "string" },
          { "name": "q", "in": "query", "type": "string" },
          { "name": "query", "in": "query", "type": "string" },
          { "name": "image", "in": "query", "type": "string" },
          { "name": "mimeType", "in": "query", "type": "string" }
        ],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "data": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": { "$ref": "#/definitions/ProductItem" }
                    },
                    "pagination": { "$ref": "#/definitions/Pagination" },
                    "aiUsed": { "type": "boolean" },
                    "query": { "type": "string" },
                    "describedAs": { "type": "string" },
                    "aiFilters": { "type": "object" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (admin/super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "503": {
            "description": "ИИ недоступен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Один товар по ID",
        "security": [{ "Bearer": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID товара (ObjectId)"
          }
        ],
        "responses": {
          "200": {
            "description": "Успех",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean", "example": true },
                "data": {
                  "type": "object",
                  "properties": {
                    "product": { "$ref": "#/definitions/ProductItem" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Товар не найден",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Обновить товар",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "schema": { "$ref": "#/definitions/UpdateProductBody" }
          }
        ],
        "responses": {
          "200": {
            "description": "Обновлено",
            "schema": { "$ref": "#/definitions/ProductItemResponse" }
          },
          "400": {
            "description": "Категория не найдена",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (admin или super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Товар не найден",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Удалить товар",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": {
            "description": "Удалено",
            "schema": { "$ref": "#/definitions/DeleteProductResponse" }
          },
          "401": {
            "description": "Нет/неверный токен",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "403": {
            "description": "Нет прав (admin или super_admin)",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          },
          "404": {
            "description": "Товар не найден",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    }
  },
  "definitions": {
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": false },
        "data": {
          "type": "object",
          "properties": {
            "message": { "type": "string", "description": "Текст ошибки" }
          }
        }
      }
    },
    "LoginResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": true },
        "data": {
          "type": "object",
          "properties": {
            "user": { "$ref": "#/definitions/UserObject" },
            "token": { "type": "string" }
          }
        }
      }
    },
    "MeResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": true },
        "data": {
          "type": "object",
          "properties": {
            "user": { "$ref": "#/definitions/UserObject" }
          }
        }
      }
    },
    "UserObject": {
      "type": "object",
      "properties": {
        "_id": { "type": "string" },
        "email": { "type": "string" },
        "storeName": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "SUPER_ADMIN"] },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Pagination": {
      "type": "object",
      "properties": {
        "page": { "type": "integer" },
        "limit": { "type": "integer" },
        "total": { "type": "integer" },
        "totalPages": { "type": "integer" }
      }
    },
    "GetAdminsResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean", "example": true },
        "data": {
          "type": "object",
          "properties": {
            "users": {
              "type": "array",
              "items": { "$ref": "#/definitions/UserObject" }
            },
            "pagination": { "$ref": "#/definitions/Pagination" }
          }
        }
      }
    },
    "CreateAdminResponse": {
